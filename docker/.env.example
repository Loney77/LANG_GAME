# Параметры для docker compose. Скопируйте в docker/.env и подставьте свои значения.
#   Windows PowerShell: Copy-Item docker/.env.example docker/.env

# Authtoken из личного кабинета ngrok (https://dashboard.ngrok.com/get-started/your-authtoken).
NGROK_AUTHTOKEN=

# Постоянный домен ngrok (раздел Domains в кабинете). Полный URL со схемой.
NGROK_DOMAIN=https://your-domain.ngrok-free.dev

# Ключ подписи JWT (для рабочей среды задайте собственное значение).
JWT_SECRET=change-me-dev-secret-change-me-dev-secret-32b
