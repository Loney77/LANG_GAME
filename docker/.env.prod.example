# Переменные для продакшн-развёртывания (docker-compose.prod.yml).
# Скопируйте в docker/.env на сервере и заполните.

# Доменное имя сайта для HTTPS (Caddy автоматически получит сертификат Let's Encrypt).
# Должно публично резолвиться на IP сервера. Без своего домена можно использовать
# nip.io: <IP-сервера>.nip.io  (например 203.0.113.10.nip.io).
SITE_ADDRESS=

# Пароль пользователя базы данных.
DB_PASSWORD=

# Ключ подписи JWT (длинная случайная строка, не короче 32 символов).
JWT_SECRET=
