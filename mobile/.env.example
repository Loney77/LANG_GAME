# Адрес сервера для мобильного клиента. Скопируй этот файл в .env и подставь своё значение.
#   cp .env.example .env        (Windows PowerShell: Copy-Item .env.example .env)
#
# .env в репозиторий НЕ коммитится (см. .gitignore) — у каждого свой адрес.
# Без .env клиент использует дефолт http://localhost:8137 (см. src/config.ts).
#
# Выбери ОДНУ строку под свой сценарий и раскомментируй:

# Телефон по USB (adb reverse tcp:8137 tcp:8137):
EXPO_PUBLIC_API_URL=http://localhost:8137

# Android-эмулятор (AVD): localhost телефона != ПК
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8137

# Телефон в той же Wi-Fi (узнать IP ПК: ipconfig -> IPv4):
# EXPO_PUBLIC_API_URL=http://192.168.1.47:8137

# Разные сети — публичный туннель к серверу (cloudflared/ngrok), меняется при перезапуске:
# EXPO_PUBLIC_API_URL=https://example.trycloudflare.com
